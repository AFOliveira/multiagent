from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable


NAME_RE = re.compile(r"^[A-Za-z0-9._-]+$")
PACKAGE = "multiagent"
ENGINE_CLI = {
    "pi": "pi",
    "codex": "codex",
    "claude": "claude",
    "codex-work": "codex-work",
    "claude-work": "claude-work",
    "cursor": "agent",
}
VALID_ENGINES = set(ENGINE_CLI)


def timestamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def die(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


class ShutdownRequested(Exception):
    def __init__(self, signum: int) -> None:
        super().__init__(f"signal {signum}")
        self.signum = signum


def validate_name(label: str, value: str) -> None:
    if not value or not NAME_RE.match(value):
        die(f"invalid {label} '{value}' - only alphanumeric, dot, underscore, and hyphen allowed")


def write_file(path: Path, text: str) -> None:
    path.write_text(text + "\n", encoding="utf-8")


def read_file(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def read_package_text(*parts: str) -> str:
    try:
        return resources.files(PACKAGE).joinpath(*parts).read_text(encoding="utf-8")
    except OSError:
        die(f"package resource not found: {'/'.join(parts)}")


def read_protocol_text() -> str:
    return read_package_text("templates", "AGENTS.md")


def read_role_text(root: Path, role: str) -> str:
    local = root / "roles" / f"{role}.md"
    if local.is_file():
        return local.read_text(encoding="utf-8")
    return read_package_text("templates", "roles", f"{role}.md")


def append_job_log(job_dir: Path, summary: str, detail: str) -> None:
    with (job_dir / "log.md").open("a", encoding="utf-8") as f:
        f.write(f"## {timestamp()} - {summary}\n\n")
        f.write(detail.rstrip() + "\n\n")


def remove_file(path: Path) -> None:
    try:
        path.unlink()
    except FileNotFoundError:
        pass
    except OSError:
        pass


def write_runtime_pids(agent_dir: Path, job_dir: Path | None = None, proc: subprocess.Popen[str] | None = None) -> None:
    write_file(agent_dir / "runner.pid", str(os.getpid()))
    if job_dir is not None:
        write_file(job_dir / "runner.pid", str(os.getpid()))
    if proc is None:
        return
    write_file(agent_dir / "engine.pid", str(proc.pid))
    if job_dir is not None:
        write_file(job_dir / "engine.pid", str(proc.pid))


def clear_runtime_pids(agent_dir: Path, job_dir: Path | None = None) -> None:
    for name in ("engine.pid", "runner.pid"):
        remove_file(agent_dir / name)
        if job_dir is not None:
            remove_file(job_dir / name)


def terminate_process(proc: subprocess.Popen[str], timeout: float = 3) -> None:
    if proc.poll() is not None:
        return
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    except PermissionError:
        proc.terminate()
    try:
        proc.wait(timeout=timeout)
        return
    except subprocess.TimeoutExpired:
        pass

    try:
        os.killpg(proc.pid, signal.SIGKILL)
    except ProcessLookupError:
        return
    except PermissionError:
        proc.kill()
    proc.wait(timeout=timeout)


def run_bin(runtime_root: Path, *args: str, capture: bool = True) -> subprocess.CompletedProcess[str]:
    config_root = multiagent_root(runtime_root)
    env = os.environ.copy()
    env.setdefault("MULTIAGENT_ROOT", str(config_root))
    proc = subprocess.run(
        [str(runtime_root / "bin" / args[0]), *args[1:]],
        cwd=config_root,
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.PIPE if capture else None,
        env=env,
        check=False,
    )
    if proc.returncode != 0:
        stderr = (proc.stderr or "").strip()
        stdout = (proc.stdout or "").strip()
        detail = stderr or stdout or f"exit status {proc.returncode}"
        die(f"{args[0]} failed: {detail}", proc.returncode)
    return proc


def state_dir(root: Path) -> Path:
    env_state = os.environ.get("MULTIAGENT_STATE_DIR", "").strip()
    if env_state:
        return Path(env_state).expanduser().resolve()
    die("MULTIAGENT_STATE_DIR is required")


def multiagent_root(fallback: Path) -> Path:
    env_root = os.environ.get("MULTIAGENT_ROOT", "").strip()
    if env_root:
        return Path(env_root).expanduser().resolve()
    return fallback


class Transcript:
    def __init__(self, paths: Iterable[Path], mirror_stdout: bool = False, mirror_prefix: str = "") -> None:
        self.files = [path.open("a", encoding="utf-8", buffering=1) for path in paths]
        self.section: str | None = None
        self.mirror_stdout = mirror_stdout
        self.mirror_prefix = mirror_prefix
        self.mirror_line_start = True

    def close(self) -> None:
        for f in self.files:
            f.close()

    def write(self, text: str) -> None:
        if not text:
            return
        for f in self.files:
            f.write(text)
            f.flush()
        if self.mirror_stdout:
            sys.stdout.write(self.prefix_mirror_text(text))
            sys.stdout.flush()

    def prefix_mirror_text(self, text: str) -> str:
        if not self.mirror_prefix:
            return text
        out: list[str] = []
        for ch in text:
            if self.mirror_line_start and ch != "\n":
                out.append(self.mirror_prefix)
                self.mirror_line_start = False
            out.append(ch)
            if ch == "\n":
                self.mirror_line_start = True
        return "".join(out)

    def line(self, text: str = "") -> None:
        self.write(text + "\n")

    def heading(self, title: str) -> None:
        if self.section != title:
            self.write(f"\n### {title}\n\n")
            self.section = title

    def event(self, title: str, detail: str | None = None) -> None:
        self.section = None
        self.line()
        self.line(f"[{timestamp()}] {title}")
        if detail:
            self.line(detail.rstrip())


class Renderer:
    def __init__(self, transcript: Transcript, engine: str = "pi", agent_dir: Path | None = None) -> None:
        self.t = transcript
        self.engine = engine
        self.agent_dir = agent_dir
        self.error_message: str | None = None
        self.saw_assistant_text = False

    def render_line(self, raw: str) -> None:
        raw = raw.rstrip("\n")
        if not raw:
            return
        try:
            event = json.loads(raw)
        except json.JSONDecodeError:
            if raw.lstrip().startswith("{"):
                return
            else:
                self.t.event("output", raw)
            return
        if not isinstance(event, dict):
            return

        self.record_session(event)
        if self.engine in ("claude", "claude-work"):
            self.render_claude(event)
        elif self.engine in ("codex", "codex-work"):
            self.render_codex(event)
        elif self.engine == "cursor":
            self.render_cursor(event)
        else:
            self.render_pi(event)

    def record_session(self, event: dict[str, Any]) -> None:
        if self.agent_dir is None:
            return
        if self.engine in ("codex", "codex-work") and event.get("type") == "thread.started":
            session_id = str(event.get("thread_id") or event.get("threadId") or "").strip()
            if session_id:
                write_file(engine_session_file(self.engine, self.agent_dir), session_id)
            return
        if self.engine in ("claude", "claude-work") and event.get("type") == "system" and event.get("subtype") == "init":
            session_id = str(event.get("session_id") or event.get("sessionId") or "").strip()
            if session_id:
                write_file(engine_session_file(self.engine, self.agent_dir), session_id)
            return
        if self.engine == "cursor":
            session_id = self.first_string_for_keys(
                event,
                ("chatId", "chat_id", "conversationId", "conversation_id", "sessionId", "session_id"),
            )
            if session_id:
                write_file(engine_session_file(self.engine, self.agent_dir), session_id)

    def first_string_for_keys(self, value: Any, keys: tuple[str, ...]) -> str:
        if isinstance(value, dict):
            for key in keys:
                item = value.get(key)
                if isinstance(item, str) and item.strip():
                    return item.strip()
            for item in value.values():
                found = self.first_string_for_keys(item, keys)
                if found:
                    return found
        elif isinstance(value, list):
            for item in value:
                found = self.first_string_for_keys(item, keys)
                if found:
                    return found
        return ""

    def text_block(self, title: str, text: str) -> None:
        if not text:
            return
        self.t.heading(title)
        self.t.write(text)
        if title == "Assistant":
            self.saw_assistant_text = True

    def render_claude(self, event: dict[str, Any]) -> None:
        typ = event.get("type")
        subtype = event.get("subtype")

        if typ == "stream_event":
            inner = event.get("event")
            if isinstance(inner, dict):
                delta = inner.get("delta")
                if isinstance(delta, dict):
                    delta_type = delta.get("type")
                    if delta_type == "text_delta":
                        self.text_block("Assistant", str(delta.get("text", "")))
                        return
                    if delta_type in ("thinking_delta", "reasoning_delta"):
                        self.text_block("Thinking", str(delta.get("thinking") or delta.get("text") or ""))
                        return
                if inner.get("type"):
                    return

        if typ == "system":
            if subtype == "init":
                model = event.get("model")
                session_id = event.get("session_id")
                detail = "\n".join(
                    str(item)
                    for item in (
                        f"model: {model}" if model else "",
                        f"session: {session_id}" if session_id else "",
                    )
                    if item
                )
                self.t.event("claude session initialized", detail)
                return
            if subtype == "api_retry":
                self.t.event(
                    "claude api retry",
                    f"attempt: {event.get('attempt')}/{event.get('max_retries')}\nerror: {event.get('error')}",
                )
                return
            if subtype:
                return

        if typ == "assistant":
            if not self.saw_assistant_text:
                text = self.extract_claude_message_text(event.get("message"))
                if text:
                    self.text_block("Assistant", text)
                    return

        if typ == "result":
            if event.get("is_error"):
                self.error_message = str(event.get("result") or event.get("error") or "Claude runtime error")
            result = event.get("result")
            if result and not self.saw_assistant_text:
                self.text_block("Assistant", str(result))
            self.t.event("claude result", self.scalar_metadata(event, skip={"result"}))
            return

        self.render_generic(event)

    def extract_claude_message_text(self, message: Any) -> str:
        if not isinstance(message, dict):
            return ""
        parts: list[str] = []
        content = message.get("content")
        if isinstance(content, list):
            for item in content:
                if isinstance(item, dict) and item.get("type") == "text":
                    parts.append(str(item.get("text", "")))
        return "".join(parts)

    def render_codex(self, event: dict[str, Any]) -> None:
        typ = event.get("type")
        if typ == "thread.started":
            self.t.event("codex thread started", f"thread: {event.get('thread_id')}")
            return
        if typ == "turn.started":
            self.t.event("codex turn started")
            return
        if typ == "turn.completed":
            self.t.event("codex turn completed", self.usage_summary(event.get("usage")))
            return
        if typ == "turn.failed":
            self.error_message = self.scalar_metadata(event, skip={"type"}) or "Codex turn failed"
            self.t.event("codex turn failed", self.error_message)
            return
        if typ == "error":
            self.error_message = self.scalar_metadata(event, skip={"type"}) or "Codex runtime error"
            self.t.event("codex error", self.error_message)
            return

        if typ in ("item.started", "item.updated", "item.completed"):
            item = event.get("item")
            if isinstance(item, dict):
                self.render_codex_item(typ, item)
                return

        self.render_generic(event)

    def render_codex_item(self, event_type: str, item: dict[str, Any]) -> None:
        item_type = str(item.get("type", "item"))
        status = item.get("status")
        prefix = event_type.replace("item.", "")

        if item_type == "agent_message":
            text = item.get("text")
            if text:
                self.text_block("Assistant", str(text).rstrip() + "\n")
                return

        if item_type == "reasoning":
            text = item.get("text") or item.get("summary") or item.get("content")
            if text:
                self.text_block("Reasoning", self.plain_text(text).rstrip() + "\n")
                return

        if item_type == "command_execution":
            command = self.command_text(item.get("command"))
            detail_parts = []
            if command:
                detail_parts.append(command)
            if status:
                detail_parts.append(f"status: {status}")
            for key in ("exit_code", "duration_ms"):
                if key in item:
                    detail_parts.append(f"{key}: {item[key]}")
            output = item.get("output") or item.get("stdout") or item.get("stderr")
            if output:
                detail_parts.append(self.limit_text(self.plain_text(output)))
            self.t.event(f"command {prefix}", "\n".join(detail_parts))
            return

        if item_type in ("file_change", "patch", "plan_update", "web_search", "mcp_tool_call"):
            self.t.event(f"{item_type} {prefix}", self.scalar_metadata(item, skip={"id", "type"}))
            return

        self.t.event(f"{item_type} {prefix}", self.scalar_metadata(item, skip={"id", "type"}))

    def render_cursor(self, event: dict[str, Any]) -> None:
        typ = str(event.get("type") or "")
        text = self.result_text(event.get("text") or event.get("delta") or event.get("message"))
        if text and typ in ("text", "text_delta", "assistant", "assistant_message", "message"):
            self.text_block("Assistant", text)
            return
        if typ in ("error", "turn.failed", "failed"):
            self.error_message = self.scalar_metadata(event, skip={"type"}) or "Cursor runtime error"
            self.t.event("cursor error", self.error_message)
            return
        if typ in ("reasoning", "thinking", "thinking_delta"):
            self.text_block("Thinking", text)
            return
        self.render_generic(event)

    def render_pi(self, event: dict[str, Any]) -> None:
        typ = event.get("type")
        if typ == "session":
            return
        if typ == "message":
            self.render_message(event)
            return
        if typ in ("agent_start", "agent_end", "turn_start", "turn_end", "message_start", "message_end"):
            return
        if typ == "message_update":
            msg_event = event.get("assistantMessageEvent")
            if isinstance(msg_event, dict):
                msg_type = msg_event.get("type")
                delta = msg_event.get("delta")
                if msg_type == "text_delta":
                    self.text_block("Assistant", str(delta or ""))
                    return
                if msg_type == "thinking_delta":
                    self.text_block("Thinking", str(delta or ""))
                    return
                if msg_type in (
                    "thinking_start",
                    "thinking_end",
                    "text_start",
                    "text_end",
                    "toolcall_start",
                    "toolcall_delta",
                    "toolcall_end",
                ):
                    return
            self.render_generic(event)
            return
        if typ == "tool_execution_start":
            detail = self.command_text(event.get("args"))
            self.tool_block(str(event.get("toolName") or "tool"), detail)
            return
        if typ == "tool_execution_update":
            return
        if typ == "tool_execution_end":
            title = str(event.get("toolName") or "tool")
            if event.get("isError"):
                title += " (error)"
            self.tool_block(title, self.limit_text(self.result_text(event.get("result"))))
            return
        if typ in ("queue_update", "compaction_start", "compaction_end", "auto_retry_start", "auto_retry_end"):
            self.t.event(f"pi {typ}", self.scalar_metadata(event, skip={"type"}))
            return

        self.render_generic(event)

    def render_message(self, event: dict[str, Any]) -> None:
        message = event.get("message")
        if not isinstance(message, dict):
            self.render_generic(event)
            return
        stop_reason = str(message.get("stopReason") or "")
        error_message = self.plain_text(message.get("errorMessage") or message.get("error"))
        if stop_reason == "error" or error_message:
            detail_parts = []
            if stop_reason:
                detail_parts.append(f"stopReason: {stop_reason}")
            if error_message:
                detail_parts.append(error_message)
            detail = "\n".join(detail_parts) or "unknown Pi runtime error"
            self.error_message = error_message or detail
            self.t.event("pi error", detail)
            return
        if message.get("role") == "assistant":
            self.text_block("Assistant", self.plain_text(message.get("content")))
            return

    def render_generic(self, event: dict[str, Any]) -> None:
        return

    def tool_block(self, name: str, detail: str | None = None) -> None:
        self.t.heading("Tool Call")
        self.t.line(name)
        if detail:
            self.t.line(detail.rstrip())
        self.t.line()

    def scalar_metadata(self, value: dict[str, Any], skip: set[str] | None = None) -> str:
        skip = skip or set()
        lines: list[str] = []
        for key, item in value.items():
            if key in skip:
                continue
            if item in (None, "", [], {}):
                continue
            if isinstance(item, (dict, list, tuple)):
                continue
            lines.append(f"{key}: {self.limit_text(str(item))}")
        return "\n".join(lines)

    def plain_text(self, value: Any) -> str:
        if value is None:
            return ""
        if isinstance(value, str):
            return value
        if isinstance(value, (int, float, bool)):
            return str(value)
        if isinstance(value, dict):
            return self.result_text(value)
        if isinstance(value, (list, tuple)):
            parts = [self.plain_text(item) for item in value]
            return "\n".join(part for part in parts if part)
        return str(value)

    def command_text(self, value: Any) -> str:
        if isinstance(value, str):
            return value
        if isinstance(value, dict):
            command = value.get("command") or value.get("cmd")
            if command:
                return str(command)
            parts = []
            for key in ("path", "file", "pattern", "query"):
                if key in value and not isinstance(value[key], (dict, list, tuple)):
                    parts.append(f"{key}: {value[key]}")
            return "\n".join(parts)
        return self.plain_text(value)

    def result_text(self, value: Any) -> str:
        if value is None:
            return ""
        if isinstance(value, str):
            return value
        if isinstance(value, (int, float, bool)):
            return str(value)
        if isinstance(value, (list, tuple)):
            parts = [self.result_text(item) for item in value]
            return "\n".join(part for part in parts if part)
        if isinstance(value, dict):
            for key in ("text", "output", "stdout", "stderr", "error", "message", "delta"):
                if key in value:
                    text = self.result_text(value[key])
                    if text:
                        return text
            content = value.get("content")
            if isinstance(content, (list, tuple)):
                parts = []
                for item in content:
                    text = self.result_text(item)
                    if text:
                        parts.append(text)
                return "\n".join(parts)
            return self.scalar_metadata(value)
        return str(value)

    def usage_summary(self, value: Any) -> str:
        if not isinstance(value, dict):
            return ""
        parts = []
        for key in ("input_tokens", "output_tokens", "total_tokens", "input", "output", "totalTokens"):
            if key in value and not isinstance(value[key], (dict, list, tuple)):
                parts.append(f"{key}: {value[key]}")
        return "\n".join(parts)

    def limit_text(self, text: str, limit: int = 4000) -> str:
        if len(text) <= limit:
            return text
        return text[:limit].rstrip() + f"\n... truncated {len(text) - limit} chars"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run one named MULTIAGENT agent and render JSON output to transcript.log."
    )
    parser.add_argument("--headless", action="store_true", help="Do not mirror rendered transcript output to stdout")
    parser.add_argument("--engine", choices=sorted(VALID_ENGINES), default="pi")
    parser.add_argument("-m", "--model")
    parser.add_argument("--thinking-effort", "--effort", dest="thinking_effort")
    parser.add_argument("role")
    parser.add_argument("agent_name")
    return parser.parse_args()


def read_repo_root(root: Path) -> Path | None:
    env_root = os.environ.get("MULTIAGENT_REPO_ROOT", "").strip()
    if env_root:
        return Path(env_root).expanduser().resolve()
    try:
        text = (state_dir(root) / "repo-root").read_text(encoding="utf-8").strip()
    except OSError:
        return None
    return Path(text).expanduser().resolve() if text else None


def read_instance_id(root: Path) -> str:
    env_instance = os.environ.get("MULTIAGENT_INSTANCE_ID", "").strip()
    if env_instance:
        return env_instance
    try:
        text = (state_dir(root) / "instance-id").read_text(encoding="utf-8").strip()
    except OSError:
        return state_dir(root).name
    return text or state_dir(root).name


def model_context_prompt(
    *,
    agent_name: str,
    role: str,
    root: Path,
    repo_root: Path | None,
    interactive: bool,
    restart_text: str = "",
) -> str:
    state_root = state_dir(root)
    protocol_text = read_protocol_text().strip()
    role_text = read_role_text(root, role).strip()
    header = "interactive agent" if interactive else "agent"
    multiagent_root = repo_root or root
    return "\n\n".join(
        part
        for part in (
            f"You are {header} {agent_name}.",
            "\n".join(
                part
                for part in (
                    f"Your MULTIAGENT instance is: {read_instance_id(root)}",
                    f"Your MULTIAGENT root is: {multiagent_root}",
                    f"Your MULTIAGENT state directory is: {state_root}",
                    "Use the `multiagent agent ...` protocol utilities.",
                    "Treat repository paths as relative to the MULTIAGENT root. Treat tasks/, jobs/, agents/, runs/, and logs/ as relative to the MULTIAGENT state directory.",
                )
                if part
            ),
            "## MULTIAGENT Generic Protocol\n\n" + protocol_text,
            f"## Role Instructions: {role}\n\n" + role_text,
            restart_text.strip(),
        )
        if part
    )


def initial_user_prompt() -> str:
    return "Process your assigned MULTIAGENT job now."


def codex_config_value(value: str) -> str:
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def engine_executable(engine: str) -> str:
    return ENGINE_CLI[engine]


def engine_session_file(engine: str, agent_dir: Path) -> Path:
    if engine == "cursor":
        return agent_dir / "cursor-chat-id"
    return agent_dir / f"{engine}-session-id"


def prepare_engine_session(engine: str, agent_dir: Path) -> None:
    if engine in ("claude", "claude-work"):
        path = engine_session_file(engine, agent_dir)
        if not read_file(path):
            write_file(path, str(uuid.uuid4()))
    if engine == "cursor":
        path = engine_session_file(engine, agent_dir)
        if read_file(path):
            return
        proc = subprocess.run(
            [engine_executable(engine), "create-chat"],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
        if proc.returncode != 0:
            detail = (proc.stderr or proc.stdout).strip() or f"exit status {proc.returncode}"
            die(f"failed to create Cursor chat for resumable worker session: {detail}", proc.returncode)
        chat_id = proc.stdout.strip().splitlines()[-1].strip() if proc.stdout.strip() else ""
        if not chat_id:
            die("agent create-chat returned no chat id")
        write_file(path, chat_id)


def build_command(
    engine: str,
    model: str | None,
    thinking_effort: str | None,
    agent_dir: Path,
    context_prompt: str,
) -> list[str]:
    if engine == "pi":
        cmd = ["pi", "-p", "--mode", "json"]
        if model:
            cmd.extend(["--model", model])
        if thinking_effort:
            cmd.extend(["--thinking", thinking_effort])
        cmd.extend(
            [
                "--append-system-prompt",
                context_prompt,
                "--session-dir",
                str(agent_dir / "pi-session"),
                initial_user_prompt(),
            ]
        )
        return cmd
    if engine in ("codex", "codex-work"):
        session_id = read_file(engine_session_file(engine, agent_dir))
        cmd = [engine_executable(engine), "exec"]
        if session_id:
            cmd.append("resume")
        cmd.extend(
            [
                "--json",
                "--output-last-message",
                str(agent_dir / "last-message.md"),
                "--dangerously-bypass-approvals-and-sandbox",
            ]
        )
        if model:
            cmd.extend(["--model", model])
        if thinking_effort:
            cmd.extend(["-c", f"model_reasoning_effort={codex_config_value(thinking_effort)}"])
        if session_id:
            cmd.append(session_id)
        cmd.append(context_prompt + "\n\n" + initial_user_prompt())
        return cmd
    if engine in ("claude", "claude-work"):
        cmd = [engine_executable(engine), "-p", "--dangerously-skip-permissions"]
        session_id = read_file(engine_session_file(engine, agent_dir))
        if session_id:
            if (agent_dir / f"{engine}-session-started").is_file():
                cmd.extend(["--resume", session_id])
            else:
                cmd.extend(["--session-id", session_id])
        if model:
            cmd.extend(["--model", model])
        if thinking_effort:
            cmd.extend(["--effort", thinking_effort])
        cmd.extend(
            [
                "--append-system-prompt",
                context_prompt,
                "--output-format",
                "stream-json",
                "--verbose",
                "--include-partial-messages",
                initial_user_prompt(),
            ]
        )
        return cmd
    if engine == "cursor":
        if thinking_effort:
            die("cursor engine does not support --thinking-effort; choose a thinking-capable Cursor model with --model")
        session_id = read_file(engine_session_file(engine, agent_dir))
        cmd = [
            engine_executable(engine),
            "-p",
            "--output-format",
            "stream-json",
            "--stream-partial-output",
            "--force",
            "--trust",
        ]
        if session_id:
            cmd.extend(["--resume", session_id])
        if model:
            cmd.extend(["--model", model])
        cmd.append(context_prompt + "\n\n" + initial_user_prompt())
        return cmd
    raise AssertionError(engine)


def main() -> int:
    args = parse_args()
    validate_name("role", args.role)
    validate_name("agent ID", args.agent_name)

    script_dir = Path(__file__).resolve().parent
    runtime_root = script_dir.parent
    root = multiagent_root(runtime_root)
    state_root = state_dir(root)
    repo_root = read_repo_root(root)

    executable = engine_executable(args.engine)
    if shutil.which(executable) is None:
        die(f"required command not found for engine '{args.engine}': {executable}")

    read_role_text(root, args.role)

    agent_dir_out = run_bin(runtime_root, "agent-new", args.agent_name, args.role).stdout.strip()
    if not agent_dir_out:
        die("agent-new returned no agent directory")
    agent_dir = Path(agent_dir_out)

    write_file(agent_dir / "mode", "worker")
    write_file(agent_dir / "engine", args.engine)
    if args.model:
        write_file(agent_dir / "model", args.model)
    if args.thinking_effort:
        write_file(agent_dir / "thinking_effort", args.thinking_effort)
    write_file(agent_dir / "last_started_at", timestamp())
    write_runtime_pids(agent_dir)

    while True:
        run_bin(runtime_root, "job-wait", "-r", args.role, capture=True)
        claim = run_bin(runtime_root, "job-claim", "-r", args.role, "--agent-id", args.agent_name).stdout.strip()
        if claim.startswith("CLAIMED: "):
            job_id = claim.removeprefix("CLAIMED: ").strip()
            break
        if claim == "NO_JOBS":
            continue
        die(f"unexpected job-claim output: {claim}")

    write_file(agent_dir / "current-job", job_id)

    job_dir = state_root / "jobs" / job_id
    write_runtime_pids(agent_dir, job_dir)
    prompt = model_context_prompt(
        agent_name=args.agent_name,
        role=args.role,
        root=root,
        repo_root=repo_root,
        interactive=False,
    )
    write_file(agent_dir / "prompt.md", prompt)

    agent_transcript = agent_dir / "transcript.log"
    agent_error = agent_dir / "error.log"
    for path in (agent_transcript, agent_error):
        path.touch()

    append_job_log(
        job_dir,
        "Transcript",
        f"Agent transcript: agents/{args.agent_name}/transcript.log",
    )

    transcript = Transcript(
        [agent_transcript],
        mirror_stdout=not args.headless,
        mirror_prefix=f"{args.agent_name}: ",
    )
    error_files = [agent_error.open("a", encoding="utf-8", buffering=1)]
    proc: subprocess.Popen[str] | None = None
    runtime_failure = ""
    shutdown_signals = (signal.SIGTERM, signal.SIGINT)
    previous_handlers = {signum: signal.getsignal(signum) for signum in shutdown_signals}

    def request_shutdown(signum: int, _frame: Any) -> None:
        raise ShutdownRequested(signum)

    try:
        for signum in shutdown_signals:
            signal.signal(signum, request_shutdown)

        transcript.event(
            "run start",
            "\n".join(
                part
                for part in (
                    f"agent: {args.agent_name}",
                    f"role: {args.role}",
                    f"job: {job_id}",
                    f"engine: {args.engine}",
                    f"model: {args.model}" if args.model else "",
                    f"thinking_effort: {args.thinking_effort}" if args.thinking_effort else "",
                )
                if part
            ),
        )

        prepare_engine_session(args.engine, agent_dir)
        cmd = build_command(args.engine, args.model, args.thinking_effort, agent_dir, prompt)
        proc = subprocess.Popen(
            cmd,
            cwd=repo_root or root,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            encoding="utf-8",
            errors="replace",
            bufsize=1,
            start_new_session=True,
        )
        write_runtime_pids(agent_dir, job_dir, proc)

        def copy_stderr() -> None:
            assert proc.stderr is not None
            for line in proc.stderr:
                for f in error_files:
                    f.write(line)
                    f.flush()
                if sys.stderr.isatty():
                    sys.stderr.write(f"\033[31m{args.agent_name}: {line}\033[0m")
                else:
                    sys.stderr.write(f"{args.agent_name}: {line}")
                sys.stderr.flush()

        stderr_thread = threading.Thread(target=copy_stderr, daemon=True)
        stderr_thread.start()

        renderer = Renderer(transcript, args.engine, agent_dir)
        assert proc.stdout is not None
        for line in proc.stdout:
            renderer.render_line(line)

        rc = proc.wait()
        stderr_thread.join(timeout=1)
        if args.engine in ("claude", "claude-work") and rc == 0:
            write_file(agent_dir / f"{args.engine}-session-started", "1")
        if renderer.error_message:
            runtime_failure = f"{args.engine} runtime error: {renderer.error_message}"
            if rc == 0:
                rc = 1
        elif rc != 0:
            runtime_failure = f"{args.engine} process exited with status {rc}"

        detail = f"exit: {rc}"
        if runtime_failure:
            detail += f"\n{runtime_failure}"
        transcript.event("run end", detail)
        return rc
    except ShutdownRequested as exc:
        transcript.event("run interrupted", f"signal: {exc.signum}")
        return 128 + exc.signum
    finally:
        for signum, handler in previous_handlers.items():
            signal.signal(signum, handler)
        if proc is not None and proc.poll() is None:
            terminate_process(proc)
        if runtime_failure:
            completion_command = "job-fail"
            completion_message = runtime_failure
        else:
            completion_command = "job-release"
            completion_message = "Agent process exited while the job was still owned by this agent; releasing back to pending."
        completion_env = os.environ.copy()
        completion_env.setdefault("MULTIAGENT_ROOT", str(root))
        subprocess.run(
            [
                str(runtime_root / "bin" / completion_command),
                job_id,
                "--agent-id",
                args.agent_name,
                "-m",
                completion_message,
            ],
            cwd=root,
            env=completion_env,
            text=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        clear_runtime_pids(agent_dir, job_dir)
        write_file(agent_dir / "current-job", "")
        transcript.close()
        for f in error_files:
            f.close()


if __name__ == "__main__":
    raise SystemExit(main())
