#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Send periodic MULTIAGENT heartbeat prompts to an interactive agent."""

from __future__ import annotations

import argparse
import os
import signal
import sys
import threading
from datetime import datetime, timezone
from pathlib import Path

from agent_input import send_agent_input


DEFAULT_MINUTES = 15
STOP = threading.Event()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Send periodic MULTIAGENT heartbeat prompts to an interactive agent.")
    parser.add_argument(
        "--state-dir",
        default=os.environ.get("MULTIAGENT_STATE_DIR"),
        help="MULTIAGENT state directory. Defaults to MULTIAGENT_STATE_DIR.",
    )
    parser.add_argument("--agent", required=True, help="interactive agent to receive heartbeat prompts")
    parser.add_argument(
        "--minutes",
        type=int,
        default=DEFAULT_MINUTES,
        help=f"minutes between heartbeats. Defaults to {DEFAULT_MINUTES}.",
    )
    parser.add_argument("--once", action="store_true", help=argparse.SUPPRESS)
    args = parser.parse_args()
    if args.minutes < 1:
        parser.error("--minutes must be at least 1")
    return args


def heartbeat_message(now: datetime | None = None) -> str:
    now = now or datetime.now(timezone.utc)
    return f"heartbeat {now:%H:%M:%SZ} {now:%Y-%m-%d}"


def request_stop(_signum: int, _frame) -> None:
    STOP.set()


def send_heartbeat(state_dir: Path, agent: str, quiet: bool = False) -> bool:
    message = heartbeat_message()
    if not send_agent_input(state_dir, agent, message, quiet=quiet):
        return False
    print(message, flush=True)
    return True


def send_heartbeat_when_ready(state_dir: Path, agent: str) -> bool:
    while not STOP.is_set():
        if send_heartbeat(state_dir, agent, quiet=True):
            return True
        STOP.wait(1)
    return False


def main() -> int:
    args = parse_args()
    if not args.state_dir:
        print("error: --state-dir or MULTIAGENT_STATE_DIR is required", file=sys.stderr)
        return 1
    state_dir = Path(args.state_dir).resolve()
    signal.signal(signal.SIGTERM, request_stop)
    signal.signal(signal.SIGINT, request_stop)

    if args.once:
        return 0 if send_heartbeat(state_dir, args.agent) else 1

    interval_seconds = args.minutes * 60
    send_heartbeat_when_ready(state_dir, args.agent)
    while not STOP.wait(interval_seconds):
        send_heartbeat_when_ready(state_dir, args.agent)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
