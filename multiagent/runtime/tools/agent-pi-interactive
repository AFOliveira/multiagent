#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Run one named MULTIAGENT interactive agent with live browser input."""

from __future__ import annotations

import argparse
import importlib.machinery
import importlib.util
import json
import os
import shutil
import signal
import socket
import subprocess
import sys
import threading
import time
from pathlib import Path
from typing import Any


SCRIPT_DIR = Path(__file__).resolve().parent
RUNTIME_ROOT = SCRIPT_DIR.parent


def load_agent_module():
    loader = importlib.machinery.SourceFileLoader("multiagent_agent", str(SCRIPT_DIR / "agent"))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    if spec is None:
        raise RuntimeError("cannot load MULTIAGENT agent runtime module")
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module


agent_mod = load_agent_module()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run one named interactive MULTIAGENT agent.")
    parser.add_argument("--headless", action="store_true", help="Do not mirror rendered transcript output to stdout")
    parser.add_argument("-m", "--model")
    parser.add_argument("--thinking-effort", "--effort", dest="thinking_effort")
    parser.add_argument("role")
    parser.add_argument("agent_name")
    return parser.parse_args()


def write_json_line(stream, value: dict[str, Any], lock: threading.Lock) -> bool:
    with lock:
        if stream.closed:
            return False
        try:
            stream.write(json.dumps(value) + "\n")
            stream.flush()
            return True
        except BrokenPipeError:
            return False


def read_job_status(job_dir: Path) -> str:
    try:
        return (job_dir / "status").read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def read_job_owner(job_dir: Path) -> str:
    try:
        return (job_dir / "agent-id").read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def has_pi_session_history(session_dir: Path) -> bool:
    if not session_dir.is_dir():
        return False
    try:
        for path in session_dir.rglob("*"):
            if path.is_file() and not path.name.endswith(".lock"):
                return True
    except OSError:
        return False
    return False


def build_pi_rpc_command(
    model: str | None,
    thinking_effort: str | None,
    prompt: str,
    session_dir: Path,
) -> list[str]:
    command = ["pi", "--mode", "rpc"]
    if model:
        command.extend(["--model", model])
    if thinking_effort:
        command.extend(["--thinking", thinking_effort])
    command.extend(["--append-system-prompt", prompt])
    command.extend(["--session-dir", str(session_dir)])
    if has_pi_session_history(session_dir):
        command.append("--continue")
    return command


def rpc_streaming_state(event: dict[str, Any]) -> bool | None:
    typ = event.get("type")
    if typ in ("agent_start", "turn_start"):
        return True
    if typ in ("agent_end", "turn_end"):
        return False
    return None


def file_has_content(path: Path) -> bool:
    try:
        return path.stat().st_size > 0
    except OSError:
        return False


def restart_context(
    transcript_path: Path | None,
    include_restart_context: bool,
    crash_path: Path | None,
) -> str:
    if not transcript_path or not include_restart_context:
        return ""
    parts = [
        "This interactive agent has an existing transcript from a previous run.",
        f"Before answering after this restart, read enough recent history from {transcript_path} to recover the conversation context.",
    ]
    if crash_path and crash_path.is_file():
        parts.append(
            f"The previous Pi process crashed during an active turn. Read {crash_path} and the transcript, then continue if possible; if the lost turn cannot be recovered, ask the human to resend it."
        )
    return "\n".join(parts)


def recovery_prompt(transcript_path: Path, crash_path: Path) -> str:
    return (
        "Recover after an interactive agent restart. "
        f"Read the recent conversation in {transcript_path}. "
        f"Also read the crash marker at {crash_path}. "
        "If you can continue the interrupted turn from the transcript, do so. "
        "If the lost turn cannot be recovered, tell the human that the previous turn crashed and ask them to resend the missing request."
    )


def build_prompt(
    agent_name: str,
    role: str,
    root: Path,
    repo_root: Path | None = None,
    transcript_path: Path | None = None,
    include_restart_context: bool = False,
    crash_path: Path | None = None,
) -> str:
    restart_text = restart_context(transcript_path, include_restart_context, crash_path)
    return agent_mod.model_context_prompt(
        agent_name=agent_name,
        role=role,
        root=root,
        repo_root=repo_root,
        interactive=True,
        restart_text=restart_text,
    )


def main() -> int:
    args = parse_args()
    agent_mod.validate_name("role", args.role)
    agent_mod.validate_name("agent ID", args.agent_name)

    if shutil.which("pi") is None:
        agent_mod.die("required command not found: pi")

    root = agent_mod.multiagent_root(RUNTIME_ROOT)
    agent_mod.read_role_text(root, args.role)

    agent_dir_out = agent_mod.run_bin(RUNTIME_ROOT, "agent-new", args.agent_name, args.role).stdout.strip()
    if not agent_dir_out:
        agent_mod.die("agent-new returned no agent directory")
    agent_dir = Path(agent_dir_out)

    agent_mod.write_file(agent_dir / "mode", "interactive")
    agent_mod.write_file(agent_dir / "interactive", "1")
    agent_mod.write_file(agent_dir / "current-job", "")
    if args.model:
        agent_mod.write_file(agent_dir / "model", args.model)
    if args.thinking_effort:
        agent_mod.write_file(agent_dir / "thinking_effort", args.thinking_effort)
    agent_mod.write_file(agent_dir / "last_started_at", agent_mod.timestamp())
    agent_mod.write_runtime_pids(agent_dir)

    agent_transcript = agent_dir / "transcript.log"
    agent_error = agent_dir / "error.log"
    agent_busy = agent_dir / "busy"
    last_crash = agent_dir / "last-crash"
    had_transcript = file_has_content(agent_transcript)

    repo_root = agent_mod.read_repo_root(root)
    prompt = build_prompt(
        args.agent_name,
        args.role,
        root,
        repo_root,
        transcript_path=agent_transcript,
        include_restart_context=had_transcript,
        crash_path=last_crash,
    )
    agent_mod.write_file(agent_dir / "prompt.md", prompt)

    agent_transcript.touch()
    agent_error.touch()
    agent_mod.write_file(agent_busy, "0\n")

    rpc_sock = agent_dir / "rpc.sock"
    rpc_json = agent_dir / "rpc.json"
    try:
        rpc_sock.unlink()
    except OSError:
        pass
    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(str(rpc_sock))
    os.chmod(rpc_sock, 0o600)
    server.listen(16)
    server.settimeout(0.2)
    agent_mod.write_file(
        rpc_json,
        json.dumps(
            {
                "kind": "unix",
                "socket": str(rpc_sock.resolve()),
                "pid": os.getpid(),
                "started_at": agent_mod.timestamp().strip(),
            },
            indent=2,
        )
        + "\n",
    )

    transcript = agent_mod.Transcript(
        [agent_transcript],
        mirror_stdout=not args.headless,
        mirror_prefix=f"{args.agent_name}: ",
    )
    error_files = [agent_error.open("a", encoding="utf-8", buffering=1)]

    proc: subprocess.Popen[str] | None = None
    stop_event = threading.Event()
    is_streaming = threading.Event()
    stdin_lock = threading.Lock()
    shutdown_signals = (signal.SIGTERM, signal.SIGINT)
    previous_handlers = {signum: signal.getsignal(signum) for signum in shutdown_signals}

    def request_shutdown(signum: int, _frame: Any) -> None:
        stop_event.set()
        raise agent_mod.ShutdownRequested(signum)

    def set_streaming(active: bool) -> None:
        if active:
            is_streaming.set()
        else:
            is_streaming.clear()
        agent_mod.write_file(agent_busy, "1\n" if active else "0\n")

    def transcript_user_message(message: str) -> None:
        transcript.heading("User")
        transcript.write(message.rstrip() + "\n")

    def write_error_line(line: str) -> None:
        for f in error_files:
            f.write(line)
            f.flush()
        prefix = f"{args.agent_name}: "
        sys.stderr.write(prefix + line)
        sys.stderr.flush()

    def handle_input_payload(payload: dict[str, Any]) -> None:
        assert proc is not None and proc.stdin is not None
        message = str(payload.get("message") or "").strip()
        if not message:
            return
        mode = payload.get("mode") or "follow_up"
        if mode not in {"follow_up", "steer", "prompt"}:
            mode = "follow_up"
        if mode == "steer":
            command_type = "steer"
        elif is_streaming.is_set():
            command_type = "follow_up"
        else:
            command_type = "prompt"
        transcript_user_message(message)
        if command_type in {"prompt", "follow_up"}:
            set_streaming(True)
        elif command_type == "steer":
            set_streaming(False)
        sent = write_json_line(
            proc.stdin,
            {"id": f"rpc-{time.time_ns()}", "type": command_type, "message": message},
            stdin_lock,
        )
        if not sent:
            set_streaming(False)

    try:
        for signum in shutdown_signals:
            signal.signal(signum, request_shutdown)

        transcript.event(
            "interactive run start",
            "\n".join(
                part
                for part in (
                    f"agent: {args.agent_name}",
                    f"role: {args.role}",
                    "mode: interactive",
                    f"model: {args.model}" if args.model else "",
                    f"thinking_effort: {args.thinking_effort}" if args.thinking_effort else "",
                    f"rpc: agents/{args.agent_name}/rpc.sock",
                )
                if part
            ),
        )

        command = build_pi_rpc_command(args.model, args.thinking_effort, prompt, agent_dir / "pi-session")

        proc = subprocess.Popen(
            command,
            cwd=repo_root or root,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            encoding="utf-8",
            errors="replace",
            bufsize=1,
            start_new_session=True,
        )
        agent_mod.write_runtime_pids(agent_dir, None, proc)
        assert proc.stdin is not None
        assert proc.stdout is not None
        assert proc.stderr is not None

        def copy_stderr() -> None:
            assert proc is not None and proc.stderr is not None
            for line in proc.stderr:
                write_error_line(line)

        def read_rpc_stdout() -> None:
            renderer = agent_mod.Renderer(transcript)
            assert proc is not None and proc.stdout is not None
            for raw in proc.stdout:
                try:
                    event = json.loads(raw)
                except json.JSONDecodeError:
                    renderer.render_line(raw)
                    continue
                if isinstance(event, dict):
                    streaming_state = rpc_streaming_state(event)
                    if streaming_state is not None:
                        set_streaming(streaming_state)
                        if not streaming_state:
                            agent_mod.remove_file(last_crash)
                    typ = event.get("type")
                    if typ == "response" and event.get("success") is False:
                        transcript.event("pi rpc error", str(event.get("error") or event))
                        continue
                renderer.render_line(raw)

        def read_agent_input() -> None:
            while not stop_event.is_set():
                try:
                    conn, _addr = server.accept()
                except socket.timeout:
                    continue
                except OSError:
                    if stop_event.is_set():
                        return
                    transcript.event("interactive input error", "socket accept failed")
                    continue
                with conn:
                    stream = conn.makefile("r", encoding="utf-8")
                    with stream:
                        for line in stream:
                            if stop_event.is_set():
                                return
                            try:
                                payload = json.loads(line)
                            except json.JSONDecodeError:
                                transcript.event("interactive input ignored", "invalid JSON")
                                continue
                            if isinstance(payload, dict):
                                handle_input_payload(payload)

        threads = [
            threading.Thread(target=copy_stderr, daemon=True),
            threading.Thread(target=read_rpc_stdout, daemon=True),
            threading.Thread(target=read_agent_input, daemon=True),
        ]
        for thread in threads:
            thread.start()

        if last_crash.is_file():
            set_streaming(True)
            recovery = recovery_prompt(agent_transcript, last_crash)
            if not write_json_line(
                proc.stdin,
                {"id": "restart-recovery", "type": "prompt", "message": recovery},
                stdin_lock,
            ):
                set_streaming(False)

        while proc.poll() is None and not stop_event.is_set():
            time.sleep(0.2)

        stop_event.set()
        if proc.poll() is None:
            agent_mod.terminate_process(proc, timeout=5)
        rc = proc.returncode if proc.returncode is not None else 1
        was_streaming_at_exit = is_streaming.is_set()
        if rc != 0:
            crash_detail = "\n".join(
                (
                    f"exit: {rc}",
                    f"active_turn: {'yes' if was_streaming_at_exit else 'no'}",
                    f"transcript: {agent_transcript}",
                )
            )
            if was_streaming_at_exit:
                transcript.event("interactive turn crashed", crash_detail)
                agent_mod.write_file(last_crash, crash_detail)
            else:
                transcript.event("interactive process exited nonzero", crash_detail)
        elif not was_streaming_at_exit:
            agent_mod.remove_file(last_crash)
        transcript.event("interactive run end", f"exit: {rc}")
        return rc
    except agent_mod.ShutdownRequested as exc:
        transcript.event("interactive run interrupted", f"signal: {exc.signum}")
        return 128 + exc.signum
    finally:
        for signum, handler in previous_handlers.items():
            signal.signal(signum, handler)
        stop_event.set()
        agent_mod.write_file(agent_busy, "0\n")
        if proc is not None and proc.poll() is None:
            agent_mod.terminate_process(proc)
        try:
            server.close()
        except OSError:
            pass
        for cleanup in (rpc_sock, rpc_json):
            try:
                cleanup.unlink()
            except OSError:
                pass
        agent_mod.clear_runtime_pids(agent_dir, None)
        transcript.close()
        for f in error_files:
            f.close()


if __name__ == "__main__":
    raise SystemExit(main())
