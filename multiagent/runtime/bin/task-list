#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

MULTIAGENT_RUNTIME_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
MULTIAGENT_ROOT="${MULTIAGENT_ROOT:-$MULTIAGENT_RUNTIME_ROOT}"
. "$MULTIAGENT_RUNTIME_ROOT/bin/lib-multiagent"

usage() {
    echo "Usage: task-list"
    exit 1
}

[ "$#" -eq 0 ] || usage
require_tasks_dir

found=0
for task_dir in "$TASKS_DIR"/*; do
    [ -d "$task_dir" ] || continue
    found=1
    task_id="$(basename "$task_dir")"
    state="$(cat "$task_dir/state" 2>/dev/null || printf 'open')"
    title="$(
        sed -n '/^# / { s/^# *//; p; q; }' "$task_dir/spec.md" 2>/dev/null || true
    )"
    printf '%s\t%s\t%s\n' "$task_id" "$state" "$title"
done
[ "$found" -eq 1 ] || true
