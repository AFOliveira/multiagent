#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_MULTIAGENT_RUNTIME_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
GIT_MULTIAGENT_ROOT="${GIT_MULTIAGENT_ROOT:-$GIT_MULTIAGENT_RUNTIME_ROOT}"
. "$GIT_MULTIAGENT_RUNTIME_ROOT/bin/lib-git-multiagent"

if [ -d "$JOBS_DIR" ]; then
    echo "jobs/ directory already exists."
else
    mkdir -p "$JOBS_DIR"
    echo "Created jobs/ directory."
fi

if [ -d "$TASKS_DIR" ]; then
    echo "tasks/ directory already exists."
else
    mkdir -p "$TASKS_DIR"
    echo "Created tasks/ directory."
fi

if [ -d "$AGENTS_DIR" ]; then
    echo "agents/ directory already exists."
else
    mkdir -p "$AGENTS_DIR"
    echo "Created agents/ directory."
fi

echo "MULTIAGENT initialized at: $GIT_MULTIAGENT_ROOT"
echo "MULTIAGENT state at: $GIT_MULTIAGENT_STATE_DIR"
echo ""
echo "Next steps:"
echo "  1. Write a complete task:  \$EDITOR /tmp/my-first-task.md"
echo "  2. Create the task:        multiagent agent task create my-first-task /tmp/my-first-task.md"
echo "  3. Start a planner:        multiagent agent worker planner planner-1"
