#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_MULTIAGENT_RUNTIME_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
GIT_MULTIAGENT_ROOT="${GIT_MULTIAGENT_ROOT:-$GIT_MULTIAGENT_RUNTIME_ROOT}"
. "$GIT_MULTIAGENT_RUNTIME_ROOT/bin/lib-git-multiagent"

usage() {
    echo "Usage: task-comment <task-id> <message>"
    exit 1
}

[ "$#" -ge 2 ] || usage

TASK_ID="$1"
shift
MESSAGE="$*"

validate_task_id "$TASK_ID"
[ -n "$MESSAGE" ] || die "message required"
require_tasks_dir

TASK_DIR="$TASKS_DIR/$TASK_ID"

[ -d "$TASK_DIR" ] || die "task '$TASK_ID' does not exist"
append_task_log "$TASK_DIR" "Comment" "$MESSAGE"

echo "$TASK_ID: comment added"
