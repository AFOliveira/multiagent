#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Send one message to a running interactive MULTIAGENT agent."""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

from agent_input import send_agent_input


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Send one message to a MULTIAGENT interactive agent.")
    parser.add_argument(
        "--state-dir",
        default=os.environ.get("GIT_MULTIAGENT_STATE_DIR"),
        help="MULTIAGENT state directory. Defaults to GIT_MULTIAGENT_STATE_DIR.",
    )
    parser.add_argument("--mode", choices=["prompt", "follow_up", "steer"], default="prompt")
    parser.add_argument("agent")
    parser.add_argument("message", nargs="*")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    if not args.state_dir:
        print("error: --state-dir or GIT_MULTIAGENT_STATE_DIR is required", file=sys.stderr)
        return 1
    if args.message:
        message = " ".join(args.message)
    elif not sys.stdin.isatty():
        message = sys.stdin.read()
    else:
        print("error: message required", file=sys.stderr)
        return 1
    message = message.rstrip()
    if not message:
        print("error: message required", file=sys.stderr)
        return 1
    return 0 if send_agent_input(Path(args.state_dir).resolve(), args.agent, message, args.mode) else 1


if __name__ == "__main__":
    raise SystemExit(main())
